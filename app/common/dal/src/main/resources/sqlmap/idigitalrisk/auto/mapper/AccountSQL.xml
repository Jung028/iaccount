<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.alipay.alipay_plus.common.dal.auto.custom.AccountDAO">

    <!-- Custom query: select only age and paymentId -->
    <select id="queryAccountInfo" resultType="com.alipay.alipay_plus.common.dal.auto.dataobject.AccountDO">
        SELECT account_id, user_id, balance
        FROM account
        WHERE account_id = #{accountId}
    </select>

    <select id="queryHistoricalDetails" parameterType="string" resultType="com.alipay.alipay_plus.common.dal.auto.dataobject.AccountTransactionDO">
        SELECT *
        FROM test
        WHERE major = #{major}
    </select>

</mapper>
